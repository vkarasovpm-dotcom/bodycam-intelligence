# ============================================================
# Sentinel — Police Bodycam Audit System
# Environment variables (copy to .env and fill in)
# ============================================================

# --- LLM providers ---
# Featherless AI (used for Prosecution/Defense rapid layer + batch council)
# Get a key at https://featherless.ai
FEATHERLESS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mistral API (fallback model for rapid layer, optional)
# Get a key at https://console.mistral.ai
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (Vertex AI) ---
# Used for Judge consolidation and Vision context agent (Gemini 3.1 Pro).
# Requires `gcloud auth application-default login` on the machine.
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global

# Google AI Studio key (alternative Developer mode, optional)
# Only needed if you don't use Vertex AI. Vertex is the default.
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Speech-to-text ---
# Speechmatics — used for transcription with speaker diarization
# Get a key at https://portal.speechmatics.com
SPEECHMATICS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GCS bucket (for Vision agent) ---
# Bucket where bodycam videos are cached for Gemini Vision input.
# Auto-created on first run if it doesn't exist. Must be globally unique.
GCS_BUCKET=sentinel-bodycam-<your-suffix>

# --- Infra (optional) ---
VULTR_VM_IP=
